# Django local
SECRET_KEY=troque-esta-chave-em-producao
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0,*
CSRF_TRUSTED_ORIGINS=

# Banco de dados local. Em deploy, a plataforma pode preencher DATABASE_URL.
DATABASE_URL=

# IA opcional
# Sem chave, o sistema usa o modo local demonstrativo.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# GroqCloud opcional
# AI_PROVIDER=groq
# GROQ_API_KEY=sua_chave_groq_aqui
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_TRANSCRIPTION_MODEL=whisper-large-v3
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3

# Uploads
MAX_UPLOAD_MB=500

# Transcrição completa de aulas longas
TRANSCRIPTION_CHUNK_SECONDS=180
TRANSCRIPTION_OVERLAP_SECONDS=5
TRANSCRIPTION_DIRECT_MAX_MB=10
TRANSCRIPTION_FORCE_CHUNK_AFTER_SECONDS=120
TRANSCRIPTION_ALWAYS_CHUNK=true
TRANSCRIPTION_LANGUAGE=pt
