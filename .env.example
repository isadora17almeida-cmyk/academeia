# Django local
SECRET_KEY=troque-esta-chave-em-producao
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0,*
CSRF_TRUSTED_ORIGINS=

# Banco de dados local. Em deploy, a plataforma pode preencher DATABASE_URL.
DATABASE_URL=

# IA obrigatória para transcrição real de áudio/vídeo
# Sem chave, o sistema não salva transcrição demonstrativa.
AI_PROVIDER=groq
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# GroqCloud opcional
# AI_PROVIDER=groq
# GROQ_API_KEY=sua_chave_groq_aqui
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# Uploads
MAX_UPLOAD_MB=500

# Transcrição completa de aulas longas
TRANSCRIPTION_CHUNK_SECONDS=45
TRANSCRIPTION_OVERLAP_SECONDS=5
TRANSCRIPTION_DIRECT_MAX_MB=10
TRANSCRIPTION_FORCE_CHUNK_AFTER_SECONDS=45
TRANSCRIPTION_ALWAYS_CHUNK=true
TRANSCRIPTION_LANGUAGE=pt
TRANSCRIPTION_PROMPT=Aula de Direito em português do Brasil. Preserve a fala do professor e atenção a termos jurídicos.

TRANSCRIPTION_RETRY_ATTEMPTS=6

# Resumo seguro para aulas longas / Groq free tier
SUMMARY_DIRECT_CHARS=9000
SUMMARY_SOURCE_MAX_CHARS=9000
SUMMARY_MAX_OUTPUT_TOKENS=1200

SUMMARY_CHUNK_CHARS=6500
SUMMARY_MAX_OUTPUT_TOKENS=2200
